# AWS S3 Configuration
REACT_APP_AWS_ACCESS_KEY_ID=your_aws_access_key_id
REACT_APP_AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
REACT_APP_AWS_REGION=us-east-1
REACT_APP_AWS_S3_BUCKET=your_s3_bucket_name

# API Configuration
REACT_APP_API_BASE_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=10000

# Application Configuration
REACT_APP_NAME=Real Estate Admin Panel
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION=Modern Real Estate Management System

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG=false
REACT_APP_ENABLE_MOCK_DATA=true

# Upload Configuration
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_MAX_FILES_COUNT=10
REACT_APP_ALLOWED_FILE_TYPES=image/*,video/*,application/pdf

# Google Maps (if needed)
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Email Configuration (for notifications)
REACT_APP_EMAIL_SERVICE=sendgrid
REACT_APP_FROM_EMAIL=noreply@realestate.com

# Security
REACT_APP_ENABLE_HTTPS=false
REACT_APP_JWT_SECRET=your_jwt_secret_key
