# AWS S3 Configuration
VITE_AWS_ACCESS_KEY_ID=
VITE_AWS_SECRET_ACCESS_KEY=
VITE_AWS_REGION=us-east-1
VITE_AWS_S3_BUCKET=

# API Configuration
# VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_BASE_URL=https://realestatebackend-nu.vercel.app/api

VITE_API_TIMEOUT=10000

# Application Configuration
VITE_APP_NAME=Real Estate Admin Panel
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Modern Real Estate Management System

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=true

# Upload Configuration
VITE_MAX_FILE_SIZE=10485760
VITE_MAX_FILES_COUNT=10
VITE_ALLOWED_FILE_TYPES=image/*,video/*,application/pdf

# Google Maps (if needed)
VITE_GOOGLE_MAPS_API_KEY=

# Email Configuration (for notifications)
VITE_EMAIL_SERVICE=sendgrid
VITE_FROM_EMAIL=noreply@realestate.com

# Security
VITE_ENABLE_HTTPS=false
VITE_JWT_SECRET=
